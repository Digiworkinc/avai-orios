# ============================================
# ENVIRONMENT CONFIGURATION - AVAI-ORIOS
# ============================================

# GEMINI_API_KEY
# Required for Gemini AI API calls
# Users configure this via the Secrets panel in the AI Studio UI
# Or set directly in your hosting platform (Vercel, Netlify, etc.)
GEMINI_API_KEY=""

# APP_URL
# The URL where this applet is hosted
# Used for self-referential links, OAuth callbacks, and API endpoints
# Examples:
#   - Development: http://localhost:3000
#   - Production: https://yourdomain.com
#   - GitHub Pages: https://username.github.io/avai-orios-web/
APP_URL=""

# VITE_APP_BASE_PATH
# Base path for the built application (used by Vite)
# Must be prefixed with VITE_ for Vite to load it automatically
# Examples:
#   - Root domain: /
#   - Subdirectory: /avai-orios/
#   - GitHub Pages subdirectory: /avai-orios/
VITE_APP_BASE_PATH="/"

# DISABLE_HMR
# Set to 'true' to disable Hot Module Replacement (useful in AI Studio)
# Default: false (HMR enabled)
DISABLE_HMR="false"
